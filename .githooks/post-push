#!/bin/sh

if [ "${AKYODEX_SKIP_POST_PUSH_CHECK:-}" = "1" ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$repo_root" || exit 0

node scripts/push-and-check-pr-conflicts.js --skip-push
status=$?

if [ "$status" -ne 0 ]; then
  echo "post-push PR conflict check failed with exit code $status" >&2
fi

exit "$status"
